MYSQL_ROOT_PASSWORD=supersecret
MYSQL_DATABASE=local
MYSQL_USER=user
MYSQL_PASSWORD=pass
WORDPRESS_TABLE_PREFIX=wp_
WORDPRESS_DEBUG=0
PROJECT_NAME=wpproject
# Clean local domain Caddy serves the site on. A *.localhost host resolves to
# 127.0.0.1 automatically (no /etc/hosts edit needed) in Chromium browsers and Safari.
SITE_HOST=wpproject.localhost
# uid:gid PHP-FPM runs as, so it can write the bind-mounted ./wordpress. start.sh
# auto-detects this from the folder's owner; set it here (e.g. WP_USER=1000:1000,
# your `id -u`:`id -g`) only if you bring the stack up with `docker compose up` directly.
# WP_USER=1000:1000
